### Local environment example — copy to `.env` and fill values. Do NOT commit real secrets.

# Sentry
# SENTRY_DSN=https://<PUBLIC_KEY>@o<ORG_ID>.ingest.sentry.io/<PROJECT_ID>
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=
SENTRY_PROFILE_SESSION_SAMPLE_RATE=
SENTRY_PROFILE_LIFECYCLE=
SENTRY_SEND_PII=False
SENTRY_ENABLE_LOGS=False

# Django core
DEBUG=True
SECRET_KEY=
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (example)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# =============================================================================
# Adarsh Admin — Environment Variables
# Copy this file as .env and fill in production values.
# NEVER commit .env to version control.
# =============================================================================

# --- Core ---
SECRET_KEY=your-secret-key
DEBUG=False

# --- Allowed Hosts (comma-separated, include BOTH subdomains) ---
ALLOWED_HOSTS=adarshbhopal.in,www.adarshbhopal.in,panel.adarshbhopal.in

# --- Subdomain Routing ---
# When both are set, SubdomainRoutingMiddleware splits traffic.
# Leave both blank for single-domain / local dev (everything on one host).
WEBSITE_DOMAIN=www.adarshbhopal.in
PANEL_DOMAIN=panel.adarshbhopal.in

# Convenience full URLs (auto-derived from domains if omitted)
# WEBSITE_URL=https://www.adarshbhopal.in
# PANEL_URL=https://panel.adarshbhopal.in

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/adarsh_db

# --- CSRF (include BOTH subdomains) ---
CSRF_TRUSTED_ORIGINS=https://adarshbhopal.in,https://www.adarshbhopal.in,https://panel.adarshbhopal.in

# --- Session & CSRF Cookie Domain ---
# Set to the parent domain so cookies work correctly across subdomains.
# REQUIRED when using subdomain routing (WEBSITE_DOMAIN + PANEL_DOMAIN).
SESSION_COOKIE_DOMAIN=.adarshbhopal.in
CSRF_COOKIE_DOMAIN=.adarshbhopal.in

# --- Session Idle Timeout (seconds) ---
# Logs out user after this many seconds of inactivity. 0 = disabled.
# Default: 259200 (3 days). Set lower for stricter security.
# SESSION_IDLE_TIMEOUT=259200

# --- Email (SMTP) ---
# SMTP server for your domain (ask your hosting provider for the exact host)
EMAIL_HOST=mail.adarshbhopal.in
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Authenticate as the noreply mailbox (used for sending OTPs, notifications, welcome emails)
EMAIL_HOST_USER=noreply@adarshbhopal.in
EMAIL_HOST_PASSWORD=your-noreply-mailbox-password
DEFAULT_FROM_EMAIL=Adarsh Admin <noreply@adarshbhopal.in>

# Contact form submissions are sent TO this address
CONTACT_FORM_RECIPIENT=hello@adarshbhopal.in

# --- Site URL (for email links — points to the public website) ---
SITE_URL=https://www.adarshbhopal.in

# --- SSL (production) ---
SECURE_SSL_REDIRECT=True

# --- Redis Cache (required in production) ---
# Preferred form (single URL):
REDIS_URL=redis://127.0.0.1:6379/1

# Alternative component form (if REDIS_URL is omitted):
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_DB=1
# REDIS_USERNAME=
# REDIS_PASSWORD=

# Cache behavior tuning
# CACHE_DEFAULT_TIMEOUT=300
# CACHE_KEY_PREFIX=adarsh
# CACHE_VERSION=1
# REDIS_SOCKET_TIMEOUT=1.5
# REDIS_SOCKET_CONNECT_TIMEOUT=1.5
# REDIS_HEALTH_CHECK_INTERVAL=30
# REDIS_MAX_CONNECTIONS=100

# --- Gunicorn (1 CPU / 1 GB baseline) ---
# WEB_CONCURRENCY=2
# GUNICORN_THREADS=2
# GUNICORN_WORKER_CLASS=gthread
# GUNICORN_TIMEOUT=90
# GUNICORN_GRACEFUL_TIMEOUT=30
# GUNICORN_KEEPALIVE=5
# GUNICORN_MAX_REQUESTS=1000
# GUNICORN_MAX_REQUESTS_JITTER=100
# GUNICORN_BIND=unix:/run/gunicorn.sock

# --- App Version (auto-set by CD pipeline) ---
APP_VERSION=1.8.0

# --- Android Mobile Shell Policy ---
# Minimum app build allowed to continue using shell runtime.
MOBILE_SHELL_ANDROID_MIN_BUILD=1
# Latest published build (used for update recommendation).
MOBILE_SHELL_ANDROID_LATEST_BUILD=1
MOBILE_SHELL_ANDROID_LATEST_VERSION=1.0.0
# Force update regardless of build number (emergency switch).
MOBILE_SHELL_ANDROID_FORCE_UPDATE=False
# APK/update landing URL used by in-app Update button on profile and runtime update banners.
MOBILE_SHELL_ANDROID_UPDATE_URL=https://panel.adarshbhopal.in/static/website/apk/adarsh-admin.apk
MOBILE_SHELL_PRIVACY_URL=https://www.adarshbhopal.in/privacy/
MOBILE_SHELL_SUPPORT_URL=https://www.adarshbhopal.in/contact/


TIME_ZONE=Asia/Kolkata
