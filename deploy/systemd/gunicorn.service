[Unit]
Description=gunicorn daemon for Adarsh
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/adarsh
ExecStart=/var/www/adarsh/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 config.wsgi:application
Environment="DJANGO_SETTINGS_MODULE=config.settings.production"

[Install]
WantedBy=multi-user.target\n